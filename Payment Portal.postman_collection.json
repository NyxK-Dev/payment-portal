            {
              "name": "Admin Login",
              "item": [
                {
                  "name": "Login",
                  "event": [
                    {
                      "listen": "test",
                      "script": {
                        "exec": [
                          "// Parse the incoming JSON response\r",
                          "const response = pm.response.json();\r",
                          "\r",
                          "// Check if the request was successful and contains data\r",
                          "if (response.success && response.data) {\r",
                          "    // Save tokens to Environment Variables\r",
                          "    pm.environment.set(\"access_token\", response.data.access_token);\r",
                          "    pm.environment.set(\"refresh_token\", response.data.refresh_token);\r",
                          "    \r",
                          "    console.log(\"Tokens successfully updated in environment!\");\r",
                          "}"
                        ],
                        "type": "text/javascript",
                        "packages": {},
                        "requests": {}
                      }
                    }
                  ],
                  "request": {
                    "auth": {
                      "type": "bearer",
                      "bearer": [
